<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="12dp">

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/widget_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_streak_flame" />
        <TextView
            android:id="@+id/streak_count_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginTop="8dp"
            android:text="0"
            android:textColor="#673AB7"
            android:textSize="12sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Day Streak"
        android:textColor="#673AB7"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center">

        <!-- Sunday -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/day_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textColor="#9E9E9E" android:textSize="10sp" android:textStyle="bold" />
            <ImageView android:id="@+id/dot_0" android:layout_width="14dp" android:layout_height="14dp" android:layout_marginTop="4dp" android:src="@drawable/dot_background" />
        </LinearLayout>
        <!-- Monday -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/day_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="M" android:textColor="#9E9E9E" android:textSize="10sp" android:textStyle="bold" />
            <ImageView android:id="@+id/dot_1" android:layout_width="14dp" android:layout_height="14dp" android:layout_marginTop="4dp" android:src="@drawable/dot_background" />
        </LinearLayout>
        <!-- Tuesday -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/day_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T" android:textColor="#9E9E9E" android:textSize="10sp" android:textStyle="bold" />
            <ImageView android:id="@+id/dot_2" android:layout_width="14dp" android:layout_height="14dp" android:layout_marginTop="4dp" android:src="@drawable/dot_background" />
        </LinearLayout>
        <!-- Wednesday -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/day_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W" android:textColor="#9E9E9E" android:textSize="10sp" android:textStyle="bold" />
            <ImageView android:id="@+id/dot_3" android:layout_width="14dp" android:layout_height="14dp" android:layout_marginTop="4dp" android:src="@drawable/dot_background" />
        </LinearLayout>
        <!-- Thursday -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/day_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T" android:textColor="#9E9E9E" android:textSize="10sp" android:textStyle="bold" />
            <ImageView android:id="@+id/dot_4" android:layout_width="14dp" android:layout_height="14dp" android:layout_marginTop="4dp" android:src="@drawable/dot_background" />
        </LinearLayout>
        <!-- Friday -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/day_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="F" android:textColor="#9E9E9E" android:textSize="10sp" android:textStyle="bold" />
            <ImageView android:id="@+id/dot_5" android:layout_width="14dp" android:layout_height="14dp" android:layout_marginTop="4dp" android:src="@drawable/dot_background" />
        </LinearLayout>
        <!-- Saturday -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/day_6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textColor="#9E9E9E" android:textSize="10sp" android:textStyle="bold" />
            <ImageView android:id="@+id/dot_6" android:layout_width="14dp" android:layout_height="14dp" android:layout_marginTop="4dp" android:src="@drawable/dot_background" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
